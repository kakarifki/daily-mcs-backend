# Server
PORT=3000
NODE_ENV=development

# Auth — single shared secret untuk header X-API-Key (min 16 char)
API_KEY=replace-with-strong-random-secret

# Database — set EKSPLISIT, jangan andalkan interpolasi compose.
# HOST = "db" kalau pakai Postgres dari docker-compose.yml di repo ini.
# HOST = nama service Postgres kamu, atau IP/host external, kalau pakai DB lain.
DATABASE_URL=postgresql://postgres:postgres@db:5432/daily_mcs?schema=public

# Postgres (cuma dipakai service `db` di compose untuk inisialisasi)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=daily_mcs

# Storage paths (relative to project root, atau absolute kalau pakai mounted volume)
UPLOAD_DIR=./storage/uploads
OUTPUT_DIR=./storage/outputs

# Limits
MAX_UPLOAD_MB=20

# Optional: paksa Swagger UI pakai public URL ini sebagai server.
# Set saat deploy di belakang Cloudflare Flexible (yang kirim
# x-forwarded-proto=http meski user akses HTTPS) atau proxy aneh lain.
# Lokal: biarkan kosong.
# PUBLIC_URL=https://api.domainmu.com
