# Server
PORT=3000
NODE_ENV=development

# Auth — single shared secret untuk header X-API-Key
API_KEY=replace-with-strong-random-secret

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daily_mcs?schema=public"

# Storage paths (relative to project root, atau absolute kalau pakai mounted volume)
UPLOAD_DIR=./storage/uploads
OUTPUT_DIR=./storage/outputs

# Limits
MAX_UPLOAD_MB=20
